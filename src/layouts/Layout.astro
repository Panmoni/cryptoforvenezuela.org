---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Direct, wallet-to-wallet earthquake relief for the June 2026 Venezuela earthquake. No custody, no middlemen — every donation goes straight to a volunteer group on the ground in Caracas, with every delivery photo-verified.",
  noindex = false,
} = Astro.props;

const pageTitle = `${title} · Crypto for Venezuela`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL("/android-chrome-512x512.png", Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0b1220" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Crypto for Venezuela" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
  </head>
  <body>
    <main>
      <nav class="nav">
        <a href="/" class="brand">Crypto for Venezuela</a>
        <div class="nav-links">
          <a href="/#donate">Donate</a>
          <a href="/#impact">Impact</a>
          <a href="/#received">Received</a>
          <a href="/#about">About</a>
        </div>
      </nav>
      <slot />
      <footer>
        <p>
          <a href="https://github.com/Panmoni/cryptoforvenezuela.org" target="_blank" rel="noopener noreferrer">
            Source on GitHub
          </a>
          · <a href="mailto:hello@panmoni.com">hello@panmoni.com</a>
        </p>
        <p class="panmoni-credit">
          A <img src="/panmoni.svg" alt="" class="panmoni-logo" aria-hidden="true" /><a
            href="https://panmoni.com/"
            target="_blank"
            rel="noopener noreferrer"
            title="Panmoni is a Web3 product studio"
            class="panmoni-link">Panmoni</a
          > project.
        </p>
        <p class="build-hash">{__BUILD_HASH__}</p>
      </footer>
    </main>
  </body>
</html>
