---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0b1220" />

    <link rel="alternate" type="application/rss+xml" title="Crypto for Venezuela — Evidence (RSS)" href="/feed.xml" />
    <link rel="alternate" type="application/feed+json" title="Crypto for Venezuela — Evidence (JSON Feed)" href="/feed.json" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Crypto for Venezuela" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
  </head>
  <body>
    <main>
      <nav class="nav">
        <a href="/" class="brand">Crypto for Venezuela</a>
        <div class="nav-links">
          <a href="/#donate">Donate</a>
          <a href="/#impact">Impact</a>
          <a href="/#received">Received</a>
          <a href="/#about">About</a>
        </div>
      </nav>
      <slot />
      <footer>
        <p>
          <a href="https://github.com/Panmoni/cryptoforvenezuela.org" target="_blank" rel="noopener noreferrer">
            Source on GitHub
          </a>
          · <a href="mailto:hello@panmoni.com">hello@panmoni.com</a>
          · <a href="/feed.xml">RSS</a>
          · <a href="/feed.json">JSON Feed</a>
        </p>
        <p class="panmoni-credit">
          A <img src="/panmoni.svg" alt="" class="panmoni-logo" aria-hidden="true" /><a
            href="https://panmoni.com/"
            target="_blank"
            rel="noopener noreferrer"
            title="Panmoni is a Web3 product studio"
            class="panmoni-link">Panmoni</a
          > project.
        </p>
        <div class="tech-stack">
          {
            TECH_STACK.map((t) => (
              <a href={t.href} target="_blank" rel="noopener noreferrer" title={t.name} class="tech-stack-item">
                {t.img ? (
                  <img src={t.img} alt="" width="14" height="14" aria-hidden="true" />
                ) : (
                  <svg viewBox={t.viewBox} width="14" height="14" aria-hidden="true" set:html={t.svg} />
                )}
                <span>{t.name}</span>
              </a>
            ))
          }
        </div>
        <div class="tech-stack">
          {
            CHAINS.map((c) => (
              <a href={c.href} target="_blank" rel="noopener noreferrer" title={c.name} class="tech-stack-item">
                <svg viewBox={c.viewBox} width="16" height="16" aria-hidden="true" set:html={c.svg} />
              </a>
            ))
          }
        </div>
        <p class="build-hash">{__BUILD_HASH__}</p>
      </footer>
    </main>
  </body>
</html>
