---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Direct, wallet-to-wallet earthquake relief for Venezuela." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} · Crypto for Venezuela</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <main>
      <nav class="nav">
        <a href="/" class="brand">Crypto for Venezuela</a>
        <div class="nav-links">
          <a href="/#donate">Donate</a>
          <a href="/#impact">Impact</a>
          <a href="/#received">Received</a>
          <a href="/#about">About</a>
        </div>
      </nav>
      <slot />
      <footer>
        <p class="panmoni-credit">
          A <img src="/panmoni.svg" alt="" class="panmoni-logo" aria-hidden="true" /><a
            href="https://panmoni.com/"
            target="_blank"
            rel="noopener noreferrer"
            title="Panmoni is a Web3 product studio"
            class="panmoni-link">Panmoni</a
          > project.
        </p>
        <p class="build-hash">{__BUILD_HASH__}</p>
      </footer>
    </main>
  </body>
</html>
