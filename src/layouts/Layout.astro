import { getAbsoluteLocaleUrl } from "astro:i18n";
import "../styles/global.css";
import { defaultLang, languages, type Lang } from "../i18n/ui";
import { useTranslations, getPathWithoutLocale } from "../i18n/utils";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Direct, wallet-to-wallet earthquake relief for the June 2026 Venezuela earthquake. No custody, no middlemen — every donation goes straight to a volunteer group on the ground in Caracas, with every delivery photo-verified.",
  noindex = false,
} = Astro.props;

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const homeHref = lang === defaultLang ? "/" : `/${lang}/`;

const pageTitle = `${title} · Crypto for Venezuela`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL("/android-chrome-512x512.png", Astro.site);

const locales = Object.keys(languages) as Lang[];
const pathWithoutLocale = getPathWithoutLocale(Astro.url.pathname, locales);
const OG_LOCALE: Record<Lang, string> = { en: "en_US", es: "es_419", fr: "fr_FR" };

const panmoniLinkHtml =
  '<img src="/panmoni.svg" alt="" class="panmoni-logo" aria-hidden="true" /><a href="https://panmoni.com/" target="_blank" rel="noopener noreferrer" title="Panmoni is a Web3 product studio" class="panmoni-link">Panmoni</a>';
const panmoniCreditHtml = t("footer.panmoniCredit").replace("{{link}}", panmoniLinkHtml);

