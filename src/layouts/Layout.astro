---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Direct, wallet-to-wallet earthquake relief for the June 2026 Venezuela earthquake. No custody, no middlemen — every donation goes straight to a volunteer group on the ground in Caracas, with every delivery photo-verified.",
  noindex = false,
} = Astro.props;

const pageTitle = `${title} · Crypto for Venezuela`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL("/android-chrome-512x512.png", Astro.site);

// Single-color marks use currentColor so they follow the muted/hover text
// color; Solana and Ethereum keep their brand colors, matching the chain
// icons in DonationWidget.tsx.
