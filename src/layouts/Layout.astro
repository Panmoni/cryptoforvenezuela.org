// Shown as logo-only (no label) on their own row below TECH_STACK — more
// chains will be added here over time, so keep this row separate rather
// than folding it into the general tech row above.
const CHAINS = [
  {
    name: "Solana",
    href: "https://solana.com",
    viewBox: "0 0 32 32",
    svg: '<defs><linearGradient id="footer-solana-grad" x1="2" y1="26" x2="30" y2="6"><stop offset="0" stop-color="#9945FF"/><stop offset="1" stop-color="#14F195"/></linearGradient></defs><path d="M7 21.5L10.5 18H27L23.5 21.5Z" fill="url(#footer-solana-grad)"/><path d="M7 10.5L10.5 7H27L23.5 10.5Z" fill="url(#footer-solana-grad)"/><path d="M23.5 16L27 12.5H10.5L7 16Z" fill="url(#footer-solana-grad)"/>',
  },
  {
    name: "Ethereum",
    href: "https://ethereum.org",
    viewBox: "0 0 32 32",
    svg: '<path d="M16 1L16 12.8L26.5 17.8Z" fill="#8A92B2"/><path d="M16 1L5.5 17.8L16 12.8Z" fill="#62688F"/><path d="M16 20.2L16 30.9L26.5 20Z" fill="#8A92B2"/><path d="M16 30.9L16 20.2L5.5 20Z" fill="#62688F"/><path d="M16 18.4L26.5 17.8L16 12.8Z" fill="#454A75"/><path d="M5.5 17.8L16 18.4L16 12.8Z" fill="#8A92B2"/>',
