---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {
      locales.map((code) => (
        <link rel="alternate" hreflang={code} href={getAbsoluteLocaleUrl(code, pathWithoutLocale)} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={getAbsoluteLocaleUrl(defaultLang, pathWithoutLocale)} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0b1220" />

    <link rel="alternate" type="application/rss+xml" title="Crypto for Venezuela — Evidence (RSS)" href="/feed.xml" />
    <link rel="alternate" type="application/feed+json" title="Crypto for Venezuela — Evidence (JSON Feed)" href="/feed.json" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Crypto for Venezuela" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content={OG_LOCALE[lang]} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
  </head>
  <body>
    <main>
      <nav class="nav">
        <a href={homeHref} class="brand">Crypto for Venezuela</a>
        <div class="nav-links">
          <a href={`${homeHref}#donate`}>{t("nav.donate")}</a>
          <a href={`${homeHref}#impact`}>{t("nav.impact")}</a>
          <a href={`${homeHref}#received`}>{t("nav.received")}</a>
          <a href={`${homeHref}#about`}>{t("nav.about")}</a>
        </div>
        <LanguageSwitcher />
      </nav>
      <slot />
      <footer>
        <p>
          <a href="https://github.com/Panmoni/cryptoforvenezuela.org" target="_blank" rel="noopener noreferrer">
            {t("footer.sourceGithub")}
          </a>
          · <a href="https://x.com/crypto4ve" target="_blank" rel="noopener noreferrer">{t("footer.followX")}</a>
          · <a href="mailto:hello@panmoni.com">hello@panmoni.com</a>
          · <a href="/feed.xml">{t("footer.rss")}</a>
          · <a href="/feed.json">{t("footer.jsonFeed")}</a>
        </p>
        <p class="panmoni-credit" set:html={panmoniCreditHtml} />
        <p class="funds-note">{t("footer.fundsNote")}</p>
        <div class="tech-stack">
          {
            TECH_STACK.map((tech) => (
              <a href={tech.href} target="_blank" rel="noopener noreferrer" title={tech.name} class="tech-stack-item">
                {tech.img ? (
                  <img src={tech.img} alt="" width="14" height="14" aria-hidden="true" />
                ) : (
                  <svg viewBox={tech.viewBox} width="14" height="14" aria-hidden="true" set:html={tech.svg} />
                )}
                <span>{tech.name}</span>
              </a>
            ))
          }
        </div>
        <div class="tech-stack">
          {
            CHAINS.map((c) => (
              <a href={c.href} target="_blank" rel="noopener noreferrer" title={c.name} class="tech-stack-item">
                <svg viewBox={c.viewBox} width="16" height="16" aria-hidden="true" set:html={c.svg} />
              </a>
            ))
          }
        </div>
        <p class="build-hash">{__BUILD_HASH__}</p>
      </footer>
    </main>
  </body>
</html>
