---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import AdminApp from "../../components/AdminApp";
---

<Layout title="Admin review" noindex>
  <section class="hero" style="padding-top: 32px;">
    <h1>Review queue</h1>
