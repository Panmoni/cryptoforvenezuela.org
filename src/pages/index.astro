---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import DonationWidget from "../components/DonationWidget";
// ConnectSend (Phase 6, wallet-connect-and-send) is built but not wired in
// for iteration 1 — it needs a Reown project ID we don't have yet. The
// component still lives in src/components/ConnectSend.tsx; re-add the
// import and the <ConnectSend client:only="react" /> line below once one
// exists. The address+QR widget below is the full donation path for now.
---

<Layout title="Donate">
  <section class="hero">
    <h1>Direct relief for Venezuela, wallet to wallet.</h1>
    <p>
      On June 24, 2026, twin M7.2 and M7.5 earthquakes hit Venezuela. A friend of mine is on the ground in
      Caracas, buying food, hygiene supplies, and hospital materials with whatever comes in — children
      first. Every dollar you send goes straight to his wallet. Nothing passes through anyone in between.
    </p>
  </section>

  <!-- client:only — DonationWidget pulls in the `qrcode` package (Node-only
       code paths in its non-browser entry), which breaks Astro's
       SSR/prerender pass if hydrated normally. -->
  <DonationWidget client:only="react" />

  <section class="section">
    <h2>Where it's going</h2>
    <p style="color: var(--text-dim)">
      Photo-verified impact tracking is coming online shortly — every dollar received will link to the
      receipts and photos it paid for. <a href="/impact">See the impact log</a>.
    </p>
  </section>
</Layout>
